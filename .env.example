# ==============================================================================
# BACKEND ENVIRONMENT CONFIGURATIONS
# ==============================================================================
PROJECT_NAME="Agentic RAG Platform"
ENVIRONMENT="development"
DEBUG=true
API_VERSION="1.0.0"

# CORS Configuration (comma-separated origins list)
CORS_ORIGINS="http://localhost:3000,http://localhost:8000"

# PostgreSQL / SQLAlchemy Connection URL
# Replace with actual PostgreSQL connection URL or local container mapping
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agentic_rag"

# Supabase Configurations
# Obtain these credentials from your Supabase dashboard settings under API keys
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Logging Configurations
LOG_LEVEL="INFO"

# ==============================================================================
# FRONTEND ENVIRONMENT CONFIGURATIONS
# ==============================================================================
# API base URL for communication with backend routers
VITE_API_BASE_URL="http://localhost:8000"

# Supabase frontend parameters (for direct client initialization if needed later)
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"
